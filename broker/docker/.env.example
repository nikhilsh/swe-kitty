# swe-kitty harness env. Copy to .env (gitignored) and fill in.
#
#   cp harness/docker/.env.example harness/docker/.env
#   $EDITOR harness/docker/.env
#   docker compose -f harness/docker/docker-compose.yml up -d --build

# Required for the claude agent adapter to actually talk to Anthropic.
# Agents without their key still let the WS upgrade succeed (so you can
# pair the iPhone), but spawning a session against them will fail.
ANTHROPIC_API_KEY=

# Required for the codex agent adapter.
OPENAI_API_KEY=

# Optional — change the host path that ends up bind-mounted at /workspace.
# Defaults to ./workspace next to docker-compose.yml. Most users want
# this to be their actual project directory so the agent can see real
# files.
# WORKSPACE_DIR=/root/developer/projects/kitty-swe

# Optional — release tag baked into the binary version string. Override
# in CI; locally just leave blank.
# RELEASE_TAG=v0.0.x
