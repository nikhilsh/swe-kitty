// Namespace-level functions are declared in the SSH-bootstrap block
// further down; this `namespace` declaration is intentionally absent
// here to avoid two competing declarations.

dictionary ViewEventFile {
    string path;
    string rev;
};

dictionary PreviewInfo {
    u16 port;
    string url;
};

dictionary SessionStatus {
    string session;
    string assistant;
    string phase;
    string health;
    u16 rows;
    u16 cols;
    boolean yolo;
    PreviewInfo? preview;
    string? session_name;
    u32? viewers;
    string? reasoning_effort;
    string? cwd;
    string? started_at;
    string? last_activity_at;
    string? display_name;
};

dictionary ProjectSession {
    string id;
    string name;
    string assistant;
    string? branch;
    PreviewInfo? preview;
    string? reasoning_effort;
    string? cwd;
    string? started_at;
    string? last_activity_at;
    string? display_name;
};

dictionary ChatEvent {
    string role;
    string content;
    string ts;
    sequence<ViewEventFile> files;
};

dictionary ConversationItem {
    string id;
    string role;
    string kind;
    string status;
    string content;
    string ts;
    sequence<ViewEventFile> files;
    string? tool_name;
    string? command;
    i32? exit_code;
    u64? duration_ms;
    string? diff_summary;
    sequence<string> pending_options;
};

// -- SessionStoreCore reducer surface (see core/src/store/mod.rs) --
//
// Mirrors of the per-session view-state buckets the Rust reducer
// folds events into. The apps' existing per-key Swift/Kotlin
// dictionaries (terminalBuffer, chatLog, statusBySession, …)
// stay as the read source of truth in this first PR; iOS will
// `apply_*` the same event into the Rust store in parallel and
// (debug builds) assert the two snapshots agree.

dictionary TerminalViewState {
    u16 rows;
    u16 cols;
    bytes scrollback;
    boolean has_snapshot;
};

dictionary ChatViewState {
    sequence<ChatEvent> events;
    sequence<ConversationItem> conversation;
};

dictionary BrowserViewState {
    PreviewInfo? preview;
};

dictionary ProjectSessionState {
    ProjectSession session;
    SessionStatus? status;
    TerminalViewState terminal;
    ChatViewState chat;
    BrowserViewState browser;
    boolean exited;
    i32? exit_code;
};

[Enum]
interface SessionLifecycleCore {
    Creating();
    Live();
    Exited(i32 code);
    FailedToStart(string reason);
};

interface SessionStoreCore {
    constructor();

    void register_session(ProjectSession session);
    void forget_session(string session_id);

    // Reducer entry points — one per existing Swift/Kotlin `ingest*`.
    // Each returns the post-fold snapshot (or null if the session id
    // was unknown and the event didn't synthesize one — only
    // `apply_status` ever creates a placeholder).
    ProjectSessionState? apply_chat(string session_id, ChatEvent event);
    ProjectSessionState apply_status(SessionStatus status);
    ProjectSessionState? apply_exit(string session_id, i32 code);
    ProjectSessionState? apply_preview(string session_id, PreviewInfo preview);
    ProjectSessionState? apply_snapshot(string session_id, bytes gunzipped);
    ProjectSessionState? apply_pty_data(string session_id, bytes data);
    void apply_lifecycle(string session_id, SessionLifecycleCore lifecycle);

    // Read-only accessors.
    ProjectSessionState? get(string session_id);
    sequence<ProjectSession> sessions();
    sequence<ConversationItem> conversation(string session_id);
    SessionLifecycleCore? lifecycle(string session_id);
    boolean contains(string session_id);
};

[Error]
enum SweKittyError {
    "Connection",
    "Auth",
    "Protocol",
    "Json",
    "NotConnected",
    "UnknownSession",
};

dictionary SshCredentials {
    string host;
    u16 port;
    string username;
    SshAuth auth;
};

[Enum]
interface SshAuth {
    Password(string password);
    PrivateKey(string key_pem, string? passphrase);
};

dictionary SshBootstrapResult {
    u16 remote_port;
    u16 local_port;
    string token;
    string host_key_fingerprint;
    boolean reused;
};

[Error]
enum SshError {
    "Dial",
    "Handshake",
    "HostKeyRejected",
    "AuthFailed",
    "DockerMissing",
    "DockerPermission",
    "PortConflict",
    "HarnessStartTimeout",
    "BootstrapExitCode",
    "BootstrapParse",
    "PortForward",
    "Io",
};

callback interface SshHostKeyDelegate {
    boolean accept_host_key(string fingerprint);
};

namespace swe_kitty_core {
    [Async, Throws=SshError]
    SshBootstrapResult ssh_bootstrap(
        SshCredentials credentials,
        string pre_allocated_token,
        string anthropic_api_key,
        string openai_api_key,
        string? image_ref,
        SshHostKeyDelegate host_key_delegate
    );
};

[Enum]
interface ConnectionHealth {
    Connected();
    Connecting(u32 attempt, u32 max_attempts);
    Disconnected(string reason, boolean auth);
};

callback interface SweKittyDelegate {
    void on_pty_data(string session_id, bytes data);
    void on_chat_event(string session_id, ChatEvent event);
    void on_preview_ready(string session_id, PreviewInfo preview);
    void on_status(SessionStatus status);
    void on_snapshot(string session_id, bytes gunzipped);
    void on_exit(string session_id, i32 code);
    void on_disconnected(string reason);
    void on_connection_health(string session_id, ConnectionHealth health);
};

interface SweKittyClient {
    constructor(string endpoint, string bearer_token);

    [Async, Throws=SweKittyError]
    void connect(SweKittyDelegate delegate);

    void disconnect();

    void notify_network_change();

    [Async, Throws=SweKittyError]
    string create_session(string assistant, string? branch);

    [Async, Throws=SweKittyError]
    void join_session(string session_id, string? assistant);

    [Async, Throws=SweKittyError]
    void send_input(string session_id, bytes data);

    [Async, Throws=SweKittyError]
    void send_file(string session_id, string filename, string mime, bytes payload);

    [Async, Throws=SweKittyError]
    void send_chat(string session_id, string msg);

    [Async, Throws=SweKittyError]
    void resize(string session_id, u16 rows, u16 cols);

    [Async, Throws=SweKittyError]
    void switch_agent(string session_id, string assistant);

    // Ship a per-user agent OAuth credential to the broker over the
    // existing authenticated WS (docs/PLAN-AGENT-OAUTH.md §D.1, Stage 2).
    // `credential_json` is the provider-native blob (verbatim
    // `~/.codex/auth.json` for openai, `~/.claude/.credentials.json`
    // for anthropic) — the broker stores it byte-for-byte and writes it
    // into per-session agent homes when spawning the CLI.
    //
    // The broker's set_agent_credentials handler is keyed by the bearer
    // token's identity, not per-session — but the WS itself is session-
    // scoped, so this method picks any active session handle to carry
    // the control frame. Returns `NotConnected` if no session is live.
    [Async, Throws=SweKittyError]
    void set_agent_credentials(string provider, string credential_json);

    [Async, Throws=SweKittyError]
    void exit_session(string session_id);

    [Throws=SweKittyError]
    ProjectSession get_session(string session_id);

    sequence<ProjectSession> list_sessions();

    [Throws=SweKittyError]
    sequence<ConversationItem> list_conversation_items(string session_id);
};
