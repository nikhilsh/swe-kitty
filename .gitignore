# ---- Secrets / runtime ----
.swe-kitty/env
.swe-kitty/sessions/
.swe-kitty/memory/sessions/
# `recent-projects.json` is regenerated by the broker on every run
# from on-disk session metadata; safe to ignore and avoids the file
# constantly showing up as untracked in dev worktrees.
.swe-kitty/recent-projects.json
*.local.toml

# docker compose env files for the broker — never commit real API keys
broker/docker/.env
broker/docker/workspace/

# ---- swe-swe local runtime (used by the dev harness, never committed) ----
.swe-swe/

# ---- Go (broker) ----
broker/bin/
broker/dist/
*.test
*.out
coverage.txt

# ---- Rust (core) ----
core/target/
core/Cargo.lock.bak
**/*.rs.bk

# ---- iOS ----
apps/ios/build/
apps/ios/DerivedData/
apps/ios/*.xcworkspace/xcuserdata/
apps/ios/*.xcodeproj/xcuserdata/
apps/ios/*.xcodeproj/project.xcworkspace/xcuserdata/
apps/ios/Pods/
apps/ios/.swiftpm/
# generated by xcodegen — keep project.yml, not project.pbxproj
apps/ios/SweKitty.xcodeproj/
# build-rust.sh outputs: xcframework + UniFFI swift bindings
apps/ios/SweKittyCore/SweKittyCore.xcframework/
apps/ios/SweKittyCore/Sources/SweKittyCore.swift
apps/ios/SweKittyCore/.build/

# ---- Android ----
apps/android/.gradle/
apps/android/build/
apps/android/app/build/
apps/android/local.properties
apps/android/app/release.keystore
apps/android/app/src/main/jniLibs/
# UniFFI-generated Kotlin glue (sourced via kotlin.srcDir in app/build.gradle.kts)
core/generated/kotlin/

# ---- IDE / OS ----
.DS_Store
.idea/
.vscode/
.claude/
*.swp
*~

# ---- Misc ----
node_modules/
*.log
website/.next/
website/out/

# ---- Stage G: Node sidecar (xterm.js headless) ----
# `node_modules/` is already globally ignored above; keep this explicit
# so the broker release pipeline doesn't accidentally tarball deps.
broker/sidecar/node_modules/
broker/sidecar/package-lock.json
