# Copy to .conduit/env (gitignored) and fill in. KEY=VALUE per line, $VAR expansion supported.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: override harness port (default 1977)
# KITTY_PORT=1977

# Optional: public URL for remote-mode harness behind TLS terminator
# KITTY_PUBLIC_URL=https://harness.example.com
